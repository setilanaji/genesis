# Copy to .env and fill in for local development
# Never commit .env to git

# GCP
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Linear (task board)
# API key: https://linear.app/account/api-keys → Create key
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxx
# Team ID: run the curl command in README or copy from linear.app/<workspace>/settings
LINEAR_TEAM_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# AlloyDB (local: use Auth Proxy on 127.0.0.1:5432)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=genesis

# On Cloud Run, set this instead of DB_HOST/PORT:
# ALLOYDB_INSTANCE_URI=projects/PROJECT/locations/REGION/clusters/CLUSTER/instances/INSTANCE

# ADK session storage (local: SQLite auto-created, Cloud Run: set to AlloyDB URL)
# SESSION_DB_URL=postgresql+asyncpg://user:pass@host:5432/genesis

# MCP Toolbox URL (managed by start.sh)
MCP_TOOLBOX_URL=http://localhost:5000/sse
